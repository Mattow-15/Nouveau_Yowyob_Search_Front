# Variables publiques/privées du frontend YowYob Search.
# Copier vers .env.local et remplacer uniquement les placeholders.
# Ne jamais committer .env.local ou local.md.

# Google OAuth (serveur NextAuth)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=remplacez-par-un-secret-fort

# Proxy serveur vers le backend Search
BACKEND_API_URL=https://votre-backend
BACKEND_API_CLIENT_ID=yowyob-search
BACKEND_API_KEY=votre-cle-api-backend
BACKEND_API_TENANT_ID=00000000-0000-0000-0000-000000000000

# Laisser vide pour utiliser /api/gateway (recommandé)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=

PORT=3000
